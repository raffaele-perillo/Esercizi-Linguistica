/* ---------- RENDER HELPERS ---------- */
let uid = 0;
function newId(){ return 'ex'+(uid++); }

function renderMorfLine(item){
  const cls = {lex:'m-lex',der:'m-der',fle:'m-fle',vt:'m-vt',fun:'m-fun'};
  const names = {lex:'lessicale',der:'derivativo',fle:'flessivo',vt:'vocale tematica',fun:'parola funzionale'};
  return item[1].map(([m,type])=>{
    const baseType = type.split(' ')[0];
    const c = cls[baseType]||'';
    const n = names[baseType]||type;
    return `<div class="morf-line"><span class="${c}">${m}</span> &rarr; ${type.includes('(')?type:n}</div>`;
  }).join('');
}

