          <textarea id="${id}-input" placeholder="Scrivi qui la trascrizione fonetica e la descrizione di almeno 4 foni..."></textarea>
          <div class="row-actions">
            <button class="reveal-btn" onclick="toggleSolution('${id}')">Mostra soluzione</button>
          </div>
          <div class="solution" id="${id}-sol">
            <div class="label">Soluzione</div>
            <div class="ipa">${ipa}</div>
          </div>
        </div>`;
    });
    el.appendChild(wrap);
    if(g.note){
      const note = document.createElement('div');
      note.className = 'group-instructions';
      note.style.marginTop = '4px';
      note.textContent = g.note;
      el.appendChild(note);
    }
  });
}

function buildMorfologiaSection(){
  const el = document.getElementById('morfologia');
  el.innerHTML = `<div class="legend">
    <span class="m-lex">■ lessicale</span>
    <span class="m-der">■ derivativo</span>
    <span class="m-vt">■ vocale tematica</span>
    <span class="m-fle">■ flessivo</span>
    <span class="m-fun">■ parola funzionale</span>
  </div>`;
  morfologiaGroups.forEach(g=>{
    el.innerHTML += `<h2 class="group-title">${g.title}</h2><div class="group-instructions">${g.instr}</div>`;
    const wrap = document.createElement('div');
    g.items.forEach(item=>{
      const word = item[0];
      const id = newId();
      const extra = item[2] ? `<div style="margin-top:6px;font-style:italic;font-size:0.85rem;color:#665;">${item[2]}</div>` : '';
      wrap.innerHTML += `
        <div class="exercise">
          <div class="prompt">${word}</div>
          <textarea id="${id}-input" placeholder="Scomponi in morfemi e commenta le proprietà morfologiche..."></textarea>
          <div class="row-actions">
            <button class="reveal-btn" onclick="toggleSolution('${id}')">Mostra soluzione</button>
          </div>
          <div class="solution" id="${id}-sol">
            <div class="label">Soluzione</div>
            ${renderMorfLine(item)}
            ${extra}
          </div>
        </div>`;
    });
    el.appendChild(wrap);
  });
}

function renderTreeNode(n){
  if(!n.children || n.children.length===0){
    return `<li><span class="node leaf">${n.label}</span></li>`;
  }
  return `<li><span class="node">${n.label}</span><ul>${n.children.map(renderTreeNode).join('')}</ul></li>`;
}

function buildSintassiSection(){
  const el = document.getElementById('sintassi');
  el.innerHTML = `<div class="legend">Prova a disegnare l'albero su carta o descrivi la struttura a costituenti, poi confronta con la soluzione.</div>`;
  el.innerHTML += `<h2 class="group-title">Dalle simulazioni d'esame</h2>`;
  const wrap1 = document.createElement('div');
  sintassiSimulazioni.forEach(item=>{
    const id = newId();
    wrap1.innerHTML += `
      <div class="exercise">
        <div class="group-instructions" style="margin-bottom:4px;">${item.title}</div>
        <div class="prompt">${item.sentence}</div>
        <textarea id="${id}-input" placeholder="Descrivi/abbozza qui la struttura ad albero..."></textarea>
        <div class="row-actions">
          <button class="reveal-btn" onclick="toggleSolution('${id}')">Mostra soluzione</button>
        </div>
        <div class="solution" id="${id}-sol">
          <div class="label">Soluzione</div>
          ${item.note ? `<div style="font-style:italic;font-size:0.85rem;margin-bottom:8px;">${item.note}</div>` : ''}
          <div class="tree-wrap"><ul class="tree">${renderTreeNode(item.tree)}</ul></div>
        </div>
      </div>`;
  });
  el.appendChild(wrap1);

  el.innerHTML += `<h2 class="group-title">Linguistica generale — esercizi</h2><div class="group-instructions">Eseguite la rappresentazione per diagramma ad albero delle seguenti frasi (soluzioni come da documento originale).</div>`;
  const wrap2 = document.createElement('div');
  sintassiExtra.forEach(item=>{
    const id = newId();
    wrap2.innerHTML += `
      <div class="exercise">
        <div class="prompt">${item.sentence}</div>
        <textarea id="${id}-input" placeholder="Descrivi/abbozza qui la struttura ad albero..."></textarea>
        <div class="row-actions">
          <button class="reveal-btn" onclick="toggleSolution('${id}')">Mostra soluzione</button>
        </div>
        <div class="solution" id="${id}-sol">
          <div class="label">Soluzione</div>
          <img class="tree-img" src="${item.img}" alt="albero sintattico">
        </div>
      </div>`;
  });
  el.appendChild(wrap2);
}

function toggleSolution(id){
  const sol = document.getElementById(id+'-sol');
  sol.classList.toggle('shown');
}

buildFoneticaSection();
buildMorfologiaSection();
buildSintassiSection();
</script>
</body>
</html>
