<style>
  :root{
    --ink:#1f2430;
    --paper:#faf7f2;
    --accent:#7a4f9e;
    --accent-dark:#5c3877;
    --line:#ddd3c8;
    --soft:#f1ebe0;
    --good:#3f7a5c;
  }
  *{box-sizing:border-box;}
  body{
    margin:0;
    font-family:'Georgia', 'Iowan Old Style', serif;
    background:var(--paper);
    color:var(--ink);
    line-height:1.5;
  }
  .container{max-width:880px;margin:0 auto;padding:28px 20px 80px;}
  h1{
    font-size:1.7rem;
    margin-bottom:4px;
    color:var(--accent-dark);
  }
  .subtitle{color:#665;font-size:0.95rem;margin-bottom:20px;}
  .warn{
    background:#fff6e5;border:1px solid #e8cf9a;border-radius:8px;
    padding:10px 14px;font-size:0.88rem;margin-bottom:22px;color:#6b5222;
  }
  nav.tabs{
    display:flex;gap:6px;margin-bottom:24px;flex-wrap:wrap;
    border-bottom:2px solid var(--line);
  }
  nav.tabs button{
    font-family:inherit;font-size:1rem;padding:10px 18px;
    background:none;border:none;cursor:pointer;color:#847a6c;
    border-bottom:3px solid transparent;margin-bottom:-2px;
    transition:.15s;
  }
  nav.tabs button.active{color:var(--accent-dark);border-bottom-color:var(--accent);font-weight:bold;}
  nav.tabs button:hover{color:var(--accent-dark);}

  section.panel{display:none;}
  section.panel.active{display:block;animation:fade .25s;}
  @keyframes fade{from{opacity:0}to{opacity:1}}

  h2.group-title{
    font-size:1.15rem;color:var(--accent-dark);
    margin:34px 0 4px;padding-bottom:6px;border-bottom:1px solid var(--line);
  }
  h2.group-title:first-of-type{margin-top:6px;}
  .group-instructions{font-size:0.9rem;color:#665;font-style:italic;margin-bottom:14px;}

  .exercise{
    background:#fff;border:1px solid var(--line);border-radius:10px;
    padding:16px 18px;margin-bottom:14px;
  }
  .exercise .prompt{font-weight:bold;font-size:1.05rem;margin-bottom:10px;}
  .exercise textarea{
    width:100%;min-height:70px;font-family:inherit;font-size:0.95rem;
    padding:8px 10px;border:1px solid var(--line);border-radius:6px;
    background:var(--soft);resize:vertical;
  }
  .exercise .row-actions{margin-top:10px;display:flex;align-items:center;gap:10px;}
  button.reveal-btn{
    font-family:inherit;background:var(--accent);color:#fff;border:none;
    padding:8px 16px;border-radius:6px;cursor:pointer;font-size:0.9rem;
  }
  button.reveal-btn:hover{background:var(--accent-dark);}
  .solution{
    display:none;margin-top:12px;padding:12px 14px;
    background:#eef6f0;border-left:4px solid var(--good);border-radius:6px;
    font-size:0.95rem;
  }
  .solution.shown{display:block;}
  .solution .label{font-weight:bold;color:var(--good);margin-bottom:6px;font-size:0.85rem;text-transform:uppercase;letter-spacing:.03em;}
  .ipa{font-family:'Charis SIL','Doulos SIL', 'DejaVu Sans', serif;font-size:1.05rem;}
  .morf-line{margin:2px 0;}
  .morf-line .m-lex{color:#1f4e8c;font-weight:bold;}
  .morf-line .m-der{color:#a65c00;font-weight:bold;}
  .morf-line .m-fle{color:#8c1f4e;font-weight:bold;}
  .morf-line .m-vt{color:#5c8c1f;font-weight:bold;}
  .morf-line .m-fun{color:#555;font-style:italic;}
  .legend{font-size:0.8rem;color:#665;margin:10px 0 20px;padding:10px 12px;background:var(--soft);border-radius:8px;}
  .legend span{margin-right:14px;}

  .tree-img{max-width:100%;border:1px solid var(--line);border-radius:8px;margin-top:6px;}

  /* CSS tree diagram */
  ul.tree, ul.tree ul{
    padding-top:16px;position:relative;list-style:none;
    display:flex;
  }
  ul.tree{padding-top:0;}
  ul.tree ul{padding-left:0;}
  ul.tree li{
    float:left;text-align:center;list-style:none;position:relative;
    padding:16px 8px 0 8px;
  }
  ul.tree li::before, ul.tree li::after{
    content:'';position:absolute;top:0;right:50%;
    border-top:1px solid #999;width:50%;height:16px;
  }
  ul.tree li::after{right:auto;left:50%;border-left:1px solid #999;}
  ul.tree li:only-child::after, ul.tree li:only-child::before{display:none;}
  ul.tree li:first-child::before{border:0 none;}
  ul.tree li:last-child::after{border:0 none;}
  ul.tree li:last-child::before{border-right:1px solid #999;border-radius:0 5px 0 0;}
  ul.tree li:first-child::after{border-radius:5px 0 0 0;}
  ul.tree ul::before{
    content:'';position:absolute;top:0;left:50%;border-left:1px solid #999;
    width:0;height:16px;
  }
  ul.tree li .node{
    border:1px solid var(--accent);border-radius:6px;padding:4px 10px;
    display:inline-block;background:#fff;font-size:0.82rem;white-space:nowrap;
  }
  ul.tree li .node.leaf{border-color:#999;background:var(--soft);font-style:italic;}
  .tree-wrap{overflow-x:auto;padding:10px 0;}

  footer{margin-top:50px;font-size:0.8rem;color:#998;text-align:center;}
</style>
</head>
